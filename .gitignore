# Unreal Engine
# Based on https://github.com/github/gitignore/blob/main/UnrealEngine.gitignore

# Compiled binaries
Binaries/*
Plugins/**/Binaries/*

# Build artifacts
Build/*
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/**/*.ico

# Built map data
*_BuiltData.uasset

# Editor-generated config and saves
Saved/*

# Compiled source / intermediates
Intermediate/*
Plugins/**/Intermediate/*

# Shader and asset cache
DerivedDataCache/*

# Compiled object files
*.slo
*.lo
*.o
*.obj

# Precompiled headers
*.gch
*.pch

# Compiled libraries
*.so
*.dylib
*.dll
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# IDE project files (generated by engine)
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vs/
.vsconfig
.idea/

# Precompiled source art
SourceArt/**/*.png
SourceArt/**/*.tga

# macOS
.DS_Store
._*

# Build logs
logs/

# Secrets — never commit tokens or credentials
*.secret
.env

# Override global gitignore to track project rules
!CLAUDE.md
